# ============================================================
#  Embedding Worker — .env example
#  Copy to .env and fill in your values.
#  Generated automatically by install.sh during setup.
# ============================================================

# ── Identity ──────────────────────────────────────────────────────────────────
# Unique label for this worker — written to every DB row it processes.
# Use a different name on each server (e.g. worker-gpu-1, worker-cpu-berlin).
NODE_NAME=worker-1

# ── n8n Webhooks ──────────────────────────────────────────────────────────────
N8N_GET_URL=https://n8n.example.com/webhook/get-batch
N8N_SAVE_URL=https://n8n.example.com/webhook/save-vectors
N8N_API_KEY=change-me

# Optional: heartbeat POST (set to empty string to disable)
N8N_STATUS_URL=https://n8n.example.com/webhook/worker-status
STATUS_INTERVAL=10

# ── Model (HuggingFace) ────────────────────────────────────────────────────────
HF_MODEL_NAME=Qwen/Qwen3-Embedding-8B
HF_HOME=/root/.cache/huggingface

# Optional: HuggingFace API token (required for gated models)
# HF_AUTH_TOKEN=hf_...

# Optional: download model from a custom URL (zip or tar.gz archive)
# HF_MODEL_URL=

# Optional: use a model already on disk
# HF_MODEL_LOCAL_PATH=

# ── Precision / compute ───────────────────────────────────────────────────────
# PRECISION: float16 (default, requires >=16GB VRAM or >=18GB RAM)
#            float32 (CPU fallback — slower, uses ~32GB RAM)
# Do NOT use 8bit or 4bit — bitsandbytes has been removed from this project.
PRECISION=float16

# COMPUTE_MODE: cpu | nvidia | amd
# Set by install.sh. Do NOT change manually — switching modes requires
# rebuilding the Docker image (run install.sh again).
COMPUTE_MODE=cpu
GPU_TYPE=

# AMD ROCm: GFX version override for RDNA3/RDNA4 (e.g. 11.0.0 for gfx1150)
HSA_OVERRIDE_GFX_VERSION=

# ── Batch / timing ────────────────────────────────────────────────────────────
# Recommended: CPU=2-5, GPU=10-50
BATCH_SIZE=10
DELAY_SECONDS=5

# Auto-stop after duration (blank = run forever)
# Format: 30m | 8h | 1d | 1d-5h-30m
STOP_AT=

REQUEST_TIMEOUT=30

# Restart policy: always (STOP_AT empty) | on-failure (STOP_AT set)
RESTART_POLICY=always
